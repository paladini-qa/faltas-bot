# =============================================================================
# Faltas Bot — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores antes de subir o compose.
# =============================================================================

# Porta em que o servidor Express vai escutar (dentro do container)
PORT=3001

# URL de conexão com o PostgreSQL
# Em produção com docker-compose, o host é "db" (nome do serviço)
# O docker-compose.yml monta DATABASE_URL automaticamente a partir das variáveis
# POSTGRES_* abaixo — você não precisa preencher DATABASE_URL manualmente.
# Caso use um banco externo (ex: Neon, Supabase, RDS), preencha aqui e remova
# as variáveis POSTGRES_* do compose.
# DATABASE_URL=postgresql://usuario:senha@host:5432/nome_do_banco

# -----------------------------------------------------------------------------
# Credenciais do PostgreSQL gerenciado pelo docker-compose
# -----------------------------------------------------------------------------

# Usuário do banco (padrão: faltasbot)
POSTGRES_USER=faltasbot

# Senha do banco — OBRIGATÓRIO alterar em produção
POSTGRES_PASSWORD=troque_esta_senha_em_producao

# Nome do banco (padrão: faltasbot)
POSTGRES_DB=faltasbot

# -----------------------------------------------------------------------------
# Configurações de Segurança e Acesso (Recomendado para Produção/Internet)
# -----------------------------------------------------------------------------

# Chave secreta de API para proteger as rotas.
# Se não for informada, o sistema funcionará em modo aberto (sem autenticação).
# Para gerar uma chave forte de 32 bytes, rode no terminal: openssl rand -hex 32
# IMPORTANTE: Ao alterar esta chave, reconstrua o container com: docker compose up -d --build
# API_KEY=sua_chave_secreta_aqui

# Origens permitidas pelo CORS (opcional)
# Padrão: true (aceita conexões da mesma origem / todas)
# CORS_ORIGIN=https://seu-dominio.com.br


